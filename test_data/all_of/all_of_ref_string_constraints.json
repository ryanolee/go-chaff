{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "description": "Tests allOf with $ref where string constraints must be correctly merged: minLength/maxLength narrowing, format merging, and pattern.",
    "type": "object",
    "$defs": {
        "non_empty_string": {
            "type": "string",
            "minLength": 1
        },
        "short_string": {
            "type": "string",
            "maxLength": 50
        },
        "medium_string": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
        },
        "email_string": {
            "type": "string",
            "format": "email"
        },
        "bounded_string": {
            "type": "string",
            "minLength": 3,
            "maxLength": 30
        }
    },
    "properties": {
        "non_empty_short": {
            "description": "allOf: non-empty (min 1) + short (max 50). Result: 1..50 length string.",
            "allOf": [
                { "$ref": "#/$defs/non_empty_string" },
                { "$ref": "#/$defs/short_string" }
            ]
        },
        "medium_and_bounded": {
            "description": "allOf: medium (5..100) + bounded (3..30). Result: max(5,3)..min(100,30) = 5..30 length string.",
            "allOf": [
                { "$ref": "#/$defs/medium_string" },
                { "$ref": "#/$defs/bounded_string" }
            ]
        },
        "email_with_bounds": {
            "description": "allOf: email format + short string (max 50). Format takes precedence during merge; email is generated.",
            "allOf": [
                { "$ref": "#/$defs/email_string" },
                {
                    "type": "string"
                }
            ]
        },
        "triple_string_constraint": {
            "description": "allOf: non-empty + short + bounded. Result: max(1,3)..min(50,30) = 3..30 length.",
            "allOf": [
                { "$ref": "#/$defs/non_empty_string" },
                { "$ref": "#/$defs/short_string" },
                { "$ref": "#/$defs/bounded_string" }
            ]
        },
        "string_ref_with_inline": {
            "description": "allOf: medium_string ref + inline tightening to 10..20 length.",
            "allOf": [
                { "$ref": "#/$defs/medium_string" },
                {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 20
                }
            ]
        }
    },
    "required": [
        "non_empty_short",
        "medium_and_bounded",
        "email_with_bounds",
        "triple_string_constraint",
        "string_ref_with_inline"
    ]
}
