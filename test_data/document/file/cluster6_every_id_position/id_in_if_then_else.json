{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "id_in_if_then_else.json",
  "type": "object",
  "properties": {
    "guarded": {
      "type": "string",
      "if": {
        "$id": "if-short-str",
        "type": "string",
        "maxLength": 5
      },
      "then": {
        "$id": "then-min-str",
        "type": "string",
        "minLength": 2
      },
      "else": {
        "$id": "else-pattern-str",
        "type": "string",
        "pattern": "^[a-z]+$"
      }
    },
    "shortStr": { "$ref": "if-short-str" },
    "minStr": { "$ref": "then-min-str" },
    "patternStr": { "$ref": "else-pattern-str" }
  },
  "required": ["guarded", "shortStr", "minStr", "patternStr"]
}
