{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "$defs": {
        "us_address": {
            "type": "object",
            "properties": {
                "zip": { "type": "string", "pattern": "^[0-9]{5}$" }
            },
            "required": ["zip"]
        },
        "uk_address": {
            "type": "object",
            "properties": {
                "postcode": { "type": "string", "minLength": 5, "maxLength": 8 }
            },
            "required": ["postcode"]
        }
    },
    "properties": {
        "country": {
            "type": "string",
            "enum": ["US", "UK"]
        },
        "zip": { "type": "string" },
        "postcode": { "type": "string" }
    },
    "required": ["country"],
    "if": {
        "properties": {
            "country": { "const": "US" }
        },
        "required": ["country"]
    },
    "then": { "$ref": "#/$defs/us_address" },
    "else": { "$ref": "#/$defs/uk_address" }
}
