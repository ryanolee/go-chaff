{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "definitions": {
        "color": {
            "type": "string",
            "enum": ["red", "green", "blue", "yellow"]
        },
        "coordinate": {
            "type": "object",
            "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
            },
            "required": ["x", "y"]
        },
        "shape": {
            "type": "object",
            "properties": {
                "color": { "$ref": "#/definitions/color" },
                "position": { "$ref": "#/definitions/coordinate" }
            },
            "required": ["color", "position"]
        }
    },
    "properties": {
        "shapes": {
            "type": "array",
            "items": { "$ref": "#/definitions/shape" },
            "minItems": 1,
            "maxItems": 5
        },
        "origin": { "$ref": "#/definitions/coordinate" },
        "primary_color": { "$ref": "#/definitions/color" }
    },
    "required": ["shapes", "origin"]
}
